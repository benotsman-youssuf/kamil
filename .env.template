# ─── Environment Selection ──────────────────────────────────────────
VITE_ENV=production

# ─── Production (Live) ─────────────────────────────────────────────
# Use .env.local for dev (prelive) values
VITE_CLIENT_ID=
CLIENT_SECRET=
VITE_OAUTH_ENDPOINT=https://oauth2.quran.foundation
VITE_API_BASE=https://apis.quran.foundation
VITE_REDIRECT_URI=
AUTH_BASE_URL=https://oauth2.quran.foundation

# ─── Offline Quran Data ────────────────────────────────────────────
VITE_DATA_URL=

# ─── AI Chat (OpenRouter + AI SDK + MCP) ───────────────────────────
# Server-side key used by /api/chat (do NOT prefix with VITE_)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Example model: openai/gpt-4.1-mini, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openrouter/owl-alpha

# MCP endpoints used by the tool adapters in src/lib/ai/mcp.ts
QURAN_MCP_URL=https://mcp.quran.ai
HADITH_MCP_URL=https://hadith-mcp.org
